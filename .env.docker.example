# Copy to `.env.docker` and adjust before: docker compose --env-file .env.docker up --build
# Do not commit `.env.docker` (covered by .gitignore).

# --- Required ---
JWT_SECRET=change-me-to-a-long-random-string

# --- Optional overrides (compose sets Mongo/Redis URLs by default) ---
# MONGO_URI=mongodb://mongo:27017/medica
# REDIS_URL=redis://redis:6379
# PORT=5000

# Demo seed (first boot)
SEED_PASSWORD=ChangeMe123!
# Optional break-glass login for any user email (leave unset in production)
# MASTER_PASSWORD=
SEED_CORE_USERS_ONLY=true
SEED_EXTRA_USERS=false

# File management (optional; leave empty to skip external uploads)
FILE_MANAGEMENT_API_URL=
FILE_MANAGEMENT_API_KEY=

# SMTP (optional)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
