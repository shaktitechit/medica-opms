# Copy to `.env` and fill values. Never commit `.env`.

# Required: Mongo connection (pick one env name supported by src/config/env.js)
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/medica
# MONGODB_URI=
# DATABASE_URL=


# API
# PORT=5000
# JWT_SECRET=
# JWT_EXPIRES_IN=7d

# Seed users (optional; defaults to ChangeMe123! when unset)
# SEED_PASSWORD=
# Server bootstrap: include extended demo emails (see src/data/exampleUserSeeder.js)
# SEED_EXTRA_USERS=false
# SEED_CORE_USERS_ONLY=true

# CLI: `npm run seed:users` (writes permissions / roles / users to Mongo).


# SMTP — for future mail (install nodemailer when needed)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# Redis — for future queues / cache (install ioredis when needed)
# REDIS_URL=redis://127.0.0.1:6379
